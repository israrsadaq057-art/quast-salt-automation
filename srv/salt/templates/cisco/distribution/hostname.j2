{# /srv/salt/quast/templates/cisco/distribution/hostname.j2 #}
! ============================================
! Distribution Switch: {{ hostname }}
! Network Engineer: Israr Sadaq
! ============================================
!
hostname {{ hostname }}
!
! Management Interface
interface Vlan10
 description Management VLAN
 ip address {{ mgmt_ip }}
 no shutdown
!
ip default-gateway {{ mgmt_gateway }}
!
ip routing
!
! Enable SSH
ip domain-name {{ domain_name }}
crypto key generate rsa modulus 2048
!
line vty 0 4
 transport input ssh
 login local
!
! Console settings
line console 0
 logging synchronous
 exec-timeout 30 0
!
