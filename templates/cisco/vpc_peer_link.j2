
{# /srv/salt/quast/templates/cisco/vpc_peer_link.j2 #}
! ============================================
! VPC Peer Link Configuration
! ============================================
!
interface {{ peer_link_interface }}
  description *** VPC Peer Link to {{ peer_hostname }} ***
  switchport mode trunk
  switchport trunk allowed vlan 1-10,20,30,40,50,100,200,300,400,700,1000
  channel-group {{ peer_link_port_channel }} mode active
  no shutdown
!
interface port-channel {{ peer_link_port_channel }}
  description *** VPC Peer Link Port Channel ***
  switchport mode trunk
  vpc peer-link
  spanning-tree port type network
  speed 40000
!
