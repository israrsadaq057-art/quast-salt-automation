{# /srv/salt/quast/templates/cisco/access/hostname.j2 #}
! ============================================
! Access Switch: {{ hostname }}
! Location: {{ location }}
! Network Engineer: Israr Sadaq
! ============================================
!
hostname {{ hostname }}
!
! Management
interface Vlan10
 description Management VLAN
 ip address {{ mgmt_ip }}
 no shutdown
!
ip default-gateway {{ mgmt_gateway }}
!
! Enable SSH
ip domain-name quast.edu.pk
crypto key generate rsa modulus 2048
!
line vty 0 15
 transport input ssh
 login local
 exec-timeout 15 0
!
line console 0
 logging synchronous
 exec-timeout 30 0
!
service password-encryption
!
